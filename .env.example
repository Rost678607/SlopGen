# Copy to .env and fill in what you use. Loaded automatically at startup.

# LLM — only the key for the provider chosen in configs/slopgen.toml [llm] is needed.
# Gemini and OpenRouter have free tiers — good for testing without a paid key.
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
LLM_API_KEY= # for provider = "custom"

# Stock footage (both free; optional if you use assets/footage instead)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# AI-generated footage (free): use the ai_photo / ai_video visuals sources.
# Both tokens are OPTIONAL — Pollinations and HF Spaces work without a key.
# HF_TOKEN shortens Hugging Face Space queues for `wan` video.
# POLLINATIONS_TOKEN unlocks higher image rate limits / tier.
HF_TOKEN=
POLLINATIONS_TOKEN=
